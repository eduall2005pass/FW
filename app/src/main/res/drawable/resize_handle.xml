<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Three diagonal lines suggesting resize -->
    <item android:gravity="bottom|end">
        <shape android:shape="rectangle">
            <solid android:color="#FF0067C0"/>
            <size android:width="12dp" android:height="2dp"/>
        </shape>
    </item>
    <item android:gravity="bottom|end" android:bottom="4dp" android:right="4dp">
        <shape android:shape="rectangle">
            <solid android:color="#FF0067C0"/>
            <size android:width="8dp" android:height="2dp"/>
        </shape>
    </item>
    <item android:gravity="bottom|end" android:bottom="8dp" android:right="8dp">
        <shape android:shape="rectangle">
            <solid android:color="#FF0067C0"/>
            <size android:width="4dp" android:height="2dp"/>
        </shape>
    </item>
</layer-list>
