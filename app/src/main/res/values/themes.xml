<?xml version="1.0" encoding="utf-8"?>
<resources>

    <style name="Theme.FloatingWindow" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="colorPrimary">#FF0067C0</item>
        <item name="colorPrimaryVariant">#FF003E92</item>
        <item name="colorOnPrimary">#FFFFFFFF</item>
        <item name="colorSecondary">#FF4CC2FF</item>
        <item name="android:windowBackground">#FF667EEA</item>
        <item name="android:statusBarColor">#FF4A6CF7</item>
        <item name="android:navigationBarColor">#FF3D5CE5</item>
    </style>

    <style name="Theme.FloatingWindow.NoActionBar">
        <item name="windowActionBar">false</item>
        <item name="windowNoTitle">true</item>
    </style>

    <style name="AppLaunchBtn">
        <item name="android:layout_width">0dp</item>
        <item name="android:layout_height">80dp</item>
        <item name="android:orientation">vertical</item>
        <item name="android:gravity">center</item>
        <item name="android:background">@drawable/card_bg</item>
        <item name="android:clickable">true</item>
        <item name="android:focusable">true</item>
        <item name="android:foreground">?attr/selectableItemBackground</item>
    </style>

    <style name="AppIcon">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:textSize">26sp</item>
    </style>

    <style name="AppLabel">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:textSize">11sp</item>
        <item name="android:textColor">#FF333333</item>
        <item name="android:layout_marginTop">4dp</item>
        <item name="android:fontFamily">sans-serif-medium</item>
    </style>

</resources>
